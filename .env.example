# Clerk — get these from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Optional: API base URL for the typed axios client in `@/shared/lib/api`.
# Leave empty to default to `/api` (which you'd typically mock in dev).
VITE_API_BASE_URL=

# Optional: Sentry DSN. Leave empty to disable.
VITE_SENTRY_DSN=

# App branding (all optional — sensible defaults are baked in)
VITE_APP_NAME=edd-app-vite
VITE_APP_DESCRIPTION=Lightweight SPA starter built on Vite + React 19 + Clerk.
VITE_DEFAULT_LOCALE=en
