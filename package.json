{
  "name": "edd-app-vite",
  "version": "0.1.0",
  "description": "Lightweight SPA starter built on Vite + React 19 + Clerk. No DB, no SSR — just frontend with auth and an opinionated modular structure.",
  "keywords": [
    "starter",
    "spa",
    "vite",
    "react",
    "typescript",
    "template",
    "edd",
    "clerk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eddremonts86/edd-app-vite.git"
  },
  "homepage": "https://github.com/eddremonts86/edd-app-vite#readme",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "VITE_E2E=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:auth-local": "playwright test -c playwright.auth-local.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretype-check": "tsr generate",
    "type-check": "tsc --noEmit",
    "i18n:check": "tsx scripts/i18n/check-translations.ts",
    "routes:generate": "tsr generate",
    "release": "node scripts/release/create-edd-app-vite-release.mjs",
    "validate": "pnpm type-check && pnpm lint && pnpm prettier --check src/ && pnpm prettier --check tests/ && pnpm i18n:check && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/clerk-react": "^5.31.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.26",
    "@tanstack/router-plugin": "^1.168.13",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@uidotdev/usehooks": "^2.4.1",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.8",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sileo": "^0.1.5",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@clerk/shared": "^3.47.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/router-cli": "^1.167.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "react-doctor": "^0.2.14",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "web-vitals": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
